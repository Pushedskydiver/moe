{
  "name": "@moe/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc --project tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "migrate": "pnpm build && node scripts/migrate.ts",
    "backup": "pnpm build && node scripts/backup.ts",
    "restore": "pnpm build && node scripts/restore.ts"
  },
  "dependencies": {
    "kysely": "^0.29.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "fast-check": "^4.9.0"
  }
}
