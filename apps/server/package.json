{
  "name": "@moe/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc --project tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "sweep:review-queue": "pnpm build && node scripts/review-queue-sweep.ts",
    "discover:github-issues": "pnpm build && node scripts/discover-github-issues.ts",
    "create:github-issues": "pnpm build && node scripts/create-github-issues.ts",
    "reconcile:github-issues": "pnpm build && node scripts/reconcile-github-issues.ts"
  },
  "dependencies": {
    "@moe/agents": "workspace:*",
    "@moe/core": "workspace:*",
    "@moe/github": "workspace:*",
    "@moe/slack": "workspace:*",
    "kysely": "^0.29.3"
  }
}
