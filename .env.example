# Copy to .env.local and fill in real values. .env.local is gitignored — never commit it.
# apps/server reads these from process.env at boot and validates them against the schemas in
# packages/agents/src/persona-config.ts and anthropic-config.ts (neither file itself reads
# process.env — the caller does).

# --- Persona identity ---
# One of: sarah, marcus, riley, priya, dom, theo, nia (docs/decisions/CAST-ROSTER.md)
MOE_PERSONA_ID=sarah

# --- Slack (Socket Mode) — api.slack.com/apps > your app ---
# OAuth & Permissions > Bot User OAuth Token
MOE_SLACK_BOT_TOKEN=xoxb-replace-me
# Settings > Socket Mode > App-Level Token (connections:write scope)
MOE_SLACK_APP_TOKEN=xapp-replace-me
# Basic Information > App Credentials > Signing Secret
MOE_SLACK_SIGNING_SECRET=replace-me

# --- Anthropic (packages/agents, docs/VISION.md §11) ---
# A single shared account credential, not per-persona — console.anthropic.com > API Keys.
# Bare name (no MOE_ prefix), same precedent as DATABASE_URL/PORT below: the standard name
# @anthropic-ai/sdk itself defaults to when no explicit apiKey is passed to its constructor.
ANTHROPIC_API_KEY=sk-ant-replace-me

# --- Database (packages/core, docs/decisions/TOPOLOGY-AND-DATABASE.md) ---
# Local dev: point at a local Postgres. CI provisions its own via a postgres:17-alpine service container.
DATABASE_URL=postgres://postgres:password@localhost:5432/moe_dev

# --- Cost cap (packages/agents, docs/VISION.md §10, BUILD_PLAN 2.6b) ---
# Monthly spend ceiling per persona, in whole/fractional dollars ("50", "12.50") — not micros.
# New LLM calls hard-halt once this persona's spend for the current UTC month reaches it.
MOE_COST_CAP_MONTHLY=50
# Slack user ID (not a channel) the 50/80/100% spend-alert ladder DMs — api.slack.com's own
# "Copy member ID" on a user's profile.
MOE_COST_ALERT_SLACK_USER_ID=U0REPLACE

# --- Channel scoping (packages/core+agents, docs/VISION.md §5.2/§6.1, BUILD_PLAN 3.2/3.3) ---
# Comma-separated real Slack channel IDs the team treats as work-relevant (VISION §6.1's roster —
# #moe-team/#moe-incidents/#moe-research, not #moe-random). An ambient message outside this list
# never reaches the Stage 1 classifier at all. Look up each channel's ID via Slack's own "Copy
# channel ID" — these are workspace-specific, there's no meaningful default.
MOE_WORK_RELEVANT_CHANNEL_IDS=C0REPLACE1,C0REPLACE2,C0REPLACE3

# --- GitHub App (packages/github, BUILD_PLAN 4.1) ---
# github.com > Settings > Developer settings > GitHub Apps > your app > About > App ID.
MOE_GITHUB_APP_ID=123456
# The *.pem downloaded from the app's "Generate a private key" button, with real line breaks
# replaced by literal \n so it fits a single-line env var — @octokit/auth-app converts escaped
# newlines back to real ones itself, no manual decoding needed. Example shape (not a real key):
# MOE_GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----"
MOE_GITHUB_PRIVATE_KEY=replace-me
# github.com/settings/installations/<id> after installing the app on a repo — visible in the URL.
MOE_GITHUB_INSTALLATION_ID=789

# --- Server ---
# Defaults to 8080 if unset (apps/server/src/resolve-port.ts).
PORT=8080
